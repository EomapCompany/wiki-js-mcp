# Wiki.js MCP Server Configuration
# Copy this file to .env and update with your actual values

# Docker Database Configuration (for docker.yml)
POSTGRES_DB=wikijs
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=your_secure_password_here

# Wiki.js Instance Configuration
WIKIJS_API_URL=http://127.0.0.1:3000
WIKIJS_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.your_token_here

# Alternative: Username/Password Authentication
# WIKIJS_USERNAME=admin@example.com
# WIKIJS_PASSWORD=your_password

# Local Database Configuration
WIKIJS_MCP_DB=./wikijs_mappings.db

# Optional: Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=wikijs_mcp.log

# Optional: Repository Context
REPOSITORY_ROOT=./
DEFAULT_SPACE_NAME=Documentation

# OIDC Authentication (Keycloak) - required for HTTP transport
# Leave OIDC_CLIENT_ID unset to run without auth
OIDC_CONFIG_URL=https://auth.eomap.com/auth/realms/eomap/.well-known/openid-configuration
OIDC_CLIENT_ID=your-keycloak-client-id

# Confidential client: set OIDC_CLIENT_SECRET.
# Public client (Standard Flow, no secret): leave OIDC_CLIENT_SECRET unset
# and set OIDC_JWT_SIGNING_KEY instead (any random secret string).
OIDC_CLIENT_SECRET=your-keycloak-client-secret
# OIDC_JWT_SIGNING_KEY=some-random-secret-string

# Restrict access to users holding this Keycloak realm role.
# Leave unset to allow any authenticated user.
OIDC_REQUIRED_REALM_ROLE=eomap

# Public URL this server is reachable at (must match the redirect URI
# registered in Keycloak, e.g. <MCP_BASE_URL>/auth/callback)
MCP_BASE_URL=http://127.0.0.1:8000

# HTTP server bind address (defaults shown)
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# Example values (replace with your actual credentials):
# POSTGRES_PASSWORD=MySecurePassword123!
# WIKIJS_API_URL=http://localhost:3000
# WIKIJS_TOKEN=your_actual_jwt_token_here 